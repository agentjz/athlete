# Deadmouse CLI environment template
# Copy this file to .deadmouse/.env and fill real credentials.
# You can commit .deadmouse/.env.example, but do not commit .deadmouse/.env.
# Non-provider runtime settings first; provider/model configs are grouped at the bottom.

# Playwright MCP defaults
DEADMOUSE_MCP_ENABLED=1
DEADMOUSE_MCP_PLAYWRIGHT_ENABLED=1
DEADMOUSE_MCP_PLAYWRIGHT_BROWSER=chromium
DEADMOUSE_MCP_PLAYWRIGHT_OUTPUT_MODE=file
DEADMOUSE_MCP_PLAYWRIGHT_SAVE_SESSION=1

# Telegram private-chat config
DEADMOUSE_TELEGRAM_TOKEN=replace-with-your-bot-token
DEADMOUSE_TELEGRAM_ALLOWED_USER_IDS=123456789
# DEADMOUSE_TELEGRAM_API_BASE_URL=https://api.telegram.org
# DEADMOUSE_TELEGRAM_PROXY_URL=http://127.0.0.1:7897
# DEADMOUSE_TELEGRAM_POLLING_TIMEOUT_SECONDS=50
# DEADMOUSE_TELEGRAM_POLLING_LIMIT=100
# DEADMOUSE_TELEGRAM_POLLING_RETRY_BACKOFF_MS=1000
# DEADMOUSE_TELEGRAM_MESSAGE_CHUNK_CHARS=3500
# DEADMOUSE_TELEGRAM_TYPING_INTERVAL_MS=4000
# DEADMOUSE_TELEGRAM_DELIVERY_MAX_RETRIES=6
# DEADMOUSE_TELEGRAM_DELIVERY_BASE_DELAY_MS=1000
# DEADMOUSE_TELEGRAM_DELIVERY_MAX_DELAY_MS=30000

# MinerU standard API config
MINERU_API_TOKEN=replace-with-your-token
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_MODEL_VERSION=vlm
MINERU_LANGUAGE=ch
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_FORMULA=true
MINERU_POLL_INTERVAL_MS=2000
MINERU_TIMEOUT_MS=300000

# Provider/model configs (all in one place, keep one active)

# Primary: YLS Codex + GPT-5.4
DEADMOUSE_PROVIDER=openai
DEADMOUSE_API_KEY=replace-with-your-key
DEADMOUSE_BASE_URL=https://code.ylsagi.com/codex
DEADMOUSE_MODEL=gpt-5.4
DEADMOUSE_REASONING_EFFORT=xhigh
# Allowed reasoning effort: minimal | low | medium | high | xhigh

# Backup example: OpenAI relay + GPT-5.4
# GPT-5.4 uses the Responses API and still reads DEADMOUSE_API_KEY.
# There is no separate RESPONSE_API_KEY or RESPONSES_API_KEY to set.
# DEADMOUSE_PROVIDER=openai
# DEADMOUSE_API_KEY=replace-with-your-key
# DEADMOUSE_BASE_URL=https://w.ciykj.cn
# DEADMOUSE_MODEL=gpt-5.4
# DEADMOUSE_REASONING_EFFORT=high

# Backup example: DeepSeek official
# DEADMOUSE_PROVIDER=deepseek
# DEADMOUSE_API_KEY=replace-with-your-key
# DEADMOUSE_BASE_URL=https://api.deepseek.com
# DEADMOUSE_MODEL=deepseek-reasoner

# Backup example: SiliconFlow + DeepSeek V3.2
# DEADMOUSE_PROVIDER=openai-compatible
# DEADMOUSE_API_KEY=replace-with-your-key
# DEADMOUSE_BASE_URL=https://api.siliconflow.cn/v1
# DEADMOUSE_MODEL=deepseek-ai/DeepSeek-V3.2

# Backup example: SiliconFlow + MiniMax M2.5
# DEADMOUSE_PROVIDER=openai-compatible
# DEADMOUSE_API_KEY=replace-with-your-key
# DEADMOUSE_BASE_URL=https://api.siliconflow.cn/v1
# DEADMOUSE_MODEL=Pro/MiniMaxAI/MiniMax-M2.5

# Backup example: SiliconFlow + Kimi K2.5
# DEADMOUSE_PROVIDER=openai-compatible
# DEADMOUSE_API_KEY=replace-with-your-key
# DEADMOUSE_BASE_URL=https://api.siliconflow.cn/v1
# DEADMOUSE_MODEL=Pro/moonshotai/Kimi-K2.5
